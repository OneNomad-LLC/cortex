# ==============================================================================
# Cortex environment variables. Copy to `.env` and fill in.
# `.env` is gitignored. Never commit real secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# Docker layout (docker compose up)
# ------------------------------------------------------------------------------

# Host directory bind-mounted to /root/.cortex inside the cortex container.
# This is where workspaces, OAuth tokens, and engram/persona state live.
# Defaults to ./.cortex-data (relative to the compose file). Set to your
# real ~/.cortex to reuse an existing workspace:
#   Linux/macOS:  PRZM_CORTEX_HOME_HOST=${HOME}/.cortex
#   Windows:      PRZM_CORTEX_HOME_HOST=C:/Users/<you>/.cortex
PRZM_CORTEX_HOME_HOST=

# Ports published to 127.0.0.1 on the host. Change only if you have a
# reverse proxy (or Tailscale) in front.
PRZM_CORTEX_MCP_PORT=3100
PRZM_CORTEX_API_PORT=4141
PRZM_CORTEX_DASHBOARD_PORT=3030

# Which workspace to boot. Leave empty to use the active one tracked in
# ~/.cortex/state.json. Set to a slug to pin a specific workspace.
PRZM_CORTEX_WORKSPACE=

# ------------------------------------------------------------------------------
# Multi-tenant access (ADR-021) — OPTIONAL, for the hosted platform only.
# Leave ALL of these unset for a normal single-tenant / personal deploy
# (embedded PGlite or a single-tenant external Postgres). When set, cortex
# accepts przm-access scoped tokens, derives the tenant from each token, and
# enforces tenant isolation via Postgres row-level security.
# ------------------------------------------------------------------------------
# The przm-access PUBLIC verification key (JWK JSON, single line). cortex
# verifies tokens with this; it can never mint them. Distributed by the
# przm-access service operator.
PRZM_CORTEX_ACCESS_PUBLIC_JWK=
# Expected token issuer / audience (must match the przm-access service config).
PRZM_CORTEX_ACCESS_ISSUER=https://access.przm.sh
PRZM_CORTEX_ACCESS_AUDIENCE=przm-platform

# ------------------------------------------------------------------------------
# Admin dashboard bridge (Task #05) — required for the Members / Projects /
# Audit / Seat management pages in the cortex dashboard.
# Leave unset for personal / single-tenant deploys — the pages show a
# "not configured" message rather than erroring.
# ------------------------------------------------------------------------------
# Base URL of the przm-access service (no trailing slash).
PRZM_ACCESS_ADMIN_URL=https://access.przm.sh
# Platform operator key — never expose this to the browser.
PRZM_ACCESS_OPERATOR_KEY=
# Tenant UUID for member + project operations (maps to your cortex workspace).
PRZM_ACCESS_TENANT_ID=
# Organization UUID for seat management + audit log.
PRZM_ACCESS_ORG_ID=
# RLS requires external Postgres with a two-role setup. Set these in
# config/cortex.yaml under memory.pgvector, NOT here:
#   memory.pgvector.mode: external
#   memory.pgvector.enableRls: true
#   memory.pgvector.appRole: cortex_app   # restricted NOSUPERUSER role
# The connectionString base role must be a member of appRole.

# ------------------------------------------------------------------------------
# LLM provider (pick one — OpenRouter is easiest for a VPS)
# ------------------------------------------------------------------------------

# OpenRouter (recommended default — BYOK, one key covers many models,
# no local GPU needed). Get a key at https://openrouter.ai/keys.
OPENROUTER_API_KEY=

# Ollama (local GPU box only — a VPS without a GPU shouldn't use this).
# Points at the host's Ollama by default via host.docker.internal.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_FALLBACK_HOST=

# Direct BYOK providers (env vars reserved for future provider packages)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ------------------------------------------------------------------------------
# Source adapter credentials (enable adapters from the dashboard)
# ------------------------------------------------------------------------------

# Loom
LOOM_API_KEY=

# Atlassian — Confluence + Jira + Bitbucket (one API token covers all)
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
ATLASSIAN_WORKSPACE=

# Notion integration token (https://www.notion.so/profile/integrations)
NOTION_API_KEY=

# Linear personal API key (https://linear.app/settings/api)
LINEAR_API_KEY=

# GitHub — fine-grained PAT with `contents: read` on the repos you sync.
# If you use the dashboard's device-flow login, you won't need this.
GITHUB_TOKEN=

# Slack bot token (xoxb-…) with channels:history, channels:read, users:read
SLACK_BOT_TOKEN=

# Outlook / Microsoft 365 — personal Graph access token. Grab one from
# https://developer.microsoft.com/graph/graph-explorer or issue it from
# an Azure app registration with `Mail.Read` delegated permission.
# Device-flow OAuth is on the roadmap; v1 is paste-a-token.
MICROSOFT_GRAPH_TOKEN=

# Google Calendar — OAuth client, tokens persist under PRZM_CORTEX_HOME_HOST
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Obsidian — path to vault on the machine running the adapter. In Docker
# this needs an additional bind mount; defer until you want the adapter.
OBSIDIAN_VAULT_PATH=

# ------------------------------------------------------------------------------
# pgvector profile (optional — docker compose --profile pgvector up)
# ------------------------------------------------------------------------------
POSTGRES_URL=
PGVECTOR_PORT=5432

# ------------------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
