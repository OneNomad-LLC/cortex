# =============================================================================
# przm platform environment — generated by ./bootstrap.sh. Don't commit `.env`.
# =============================================================================

# -- Domains (Caddy serves these over auto-TLS via Let's Encrypt) --------------
CORTEX_DOMAIN=cortex.example.com
ACCESS_DOMAIN=access.example.com
# The access service's issuer / audience claims. Operators rarely change these.
ACCESS_ISSUER=https://access.example.com
ACCESS_AUDIENCE=przm-platform

# -- Image pins (leave 'latest' for rolling; pin to a tag for stable channels) -
ACCESS_IMAGE_TAG=latest
CORTEX_IMAGE_TAG=latest

# -- Databases (Neon recommended; any managed Postgres with RLS works) ---------
# Separate DBs (or schemas) for the access service and the cortex memory store.
# The CORTEX role MUST be a non-superuser, non-BYPASSRLS role so RLS enforces.
# The ACCESS role is the service's own (it owns its tables).
ACCESS_DATABASE_URL=postgres://access_owner:***@host.neon.tech/access_db?sslmode=require
CORTEX_DATABASE_URL=postgres://cortex_owner:***@host.neon.tech/cortex_db?sslmode=require

# Restricted role cortex's RLS-scoped path lowers into via SET LOCAL ROLE.
# cortex_owner above must be a MEMBER of this role. Required for true tenant
# isolation; without it withRlsScope sets app.tenant but the privileged owner
# bypasses RLS. See README for the role-setup SQL.
CORTEX_DB_APP_ROLE=cortex_app
# (Optional) same idea for the access service's RLS-scoped paths.
ACCESS_DB_APP_ROLE=

# -- EdDSA keypair (generated by ./bootstrap.sh; never paste manually) ---------
# Private JWK lives ONLY on the access service. Public JWK is given to cortex.
ACCESS_PRIVATE_JWK={"kty":"OKP","crv":"Ed25519","d":"REDACTED","x":"REDACTED"}
ACCESS_PUBLIC_JWK={"kty":"OKP","crv":"Ed25519","x":"REDACTED"}
ACCESS_JWT_TTL_SECONDS=3600

# -- Operator credentials (random; rotate periodically) ------------------------
# Platform operator key gating the access service's /admin surface.
ACCESS_ADMIN_API_KEY=adm_REDACTED
# Cortex's own MCP bearer (for clients that don't use access tokens — e.g. the
# operator's local Claude Code config). With access wired, operators usually
# don't need this; keep it set so the existing path still works.
CORTEX_MCP_AUTH_TOKEN=REDACTED

# -- Optional integrations -----------------------------------------------------
OPENROUTER_API_KEY=
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=
