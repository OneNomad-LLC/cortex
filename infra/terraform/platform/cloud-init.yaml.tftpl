#cloud-config
# Cloud-init for the przm platform droplet. Installs docker + deps, clones
# cortex, and runs the platform bootstrap non-interactively from Terraform
# variables. The stack is up by the time this finishes.

package_update: true
package_upgrade: false  # speeds up first boot; reboot the droplet for a full upgrade
packages:
  - ca-certificates
  - curl
  - git
  - jq
  - openssl
  - docker.io
  - docker-compose-v2

write_files:
  - path: /opt/przm/.bootstrap-env
    permissions: "0600"
    content: |
      DOMAIN_BASE=${domain_base}
      ACCESS_DATABASE_URL=${access_database_url}
      CORTEX_DATABASE_URL=${cortex_database_url}
      CORTEX_DB_APP_ROLE=${cortex_db_app_role}
      OPENROUTER_API_KEY=${openrouter_api_key}
  - path: /etc/systemd/system/przm-platform.service
    content: |
      [Unit]
      Description=przm platform (cortex + przm-access)
      Requires=docker.service
      After=docker.service network-online.target
      Wants=network-online.target

      [Service]
      Type=oneshot
      RemainAfterExit=yes
      WorkingDirectory=/opt/przm/cortex/deploy/platform
      ExecStart=/usr/bin/docker compose -f docker-compose.platform.yml --env-file .env up -d
      ExecStop=/usr/bin/docker compose -f docker-compose.platform.yml --env-file .env down

      [Install]
      WantedBy=multi-user.target

runcmd:
  - systemctl enable --now docker
  - mkdir -p /opt/przm
  - git clone --depth 1 --branch "${cortex_repo_ref}" "${cortex_repo_url}" /opt/przm/cortex
  - cd /opt/przm/cortex/deploy/platform
  - chmod +x bootstrap.sh
  - |
    set -a
    . /opt/przm/.bootstrap-env
    set +a
    BOOTSTRAP_NON_INTERACTIVE=1 ./bootstrap.sh
  - systemctl daemon-reload
  - systemctl enable --now przm-platform.service

final_message: |
  przm platform bootstrap complete in $UPTIME seconds.
  Access service: https://access.${domain_base}/health
  Cortex MCP:     https://cortex.${domain_base}/api/health
  SSH in to /opt/przm/cortex/deploy/platform to inspect logs:
    docker compose -f docker-compose.platform.yml logs -f
  Operator secrets in /opt/przm/cortex/deploy/platform/.env (chmod 600).
