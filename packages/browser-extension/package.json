{
  "name": "@onenomad/cortex-browser-extension",
  "version": "0.0.0",
  "private": true,
  "description": "Cortex browser extension — ingest web content into Cortex from Chrome.",
  "type": "module",
  "scripts": {
    "build": "tsx scripts/build-icons.ts && vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
