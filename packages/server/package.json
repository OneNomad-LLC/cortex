{
  "name": "@onenomad/przm-cortex",
  "version": "0.7.0",
  "description": "przm Cortex MCP server: unified work-knowledge layer.",
  "keywords": [
    "mcp",
    "claude",
    "cortex",
    "knowledge",
    "memory"
  ],
  "author": "OneNomad",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "przm-cortex": "./dist/index.js",
    "cortex": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "cross-env NODE_ENV=development node --import=tsx --watch src/index.ts start",
    "start": "node dist/index.js start",
    "smoke:llm": "node --import=tsx src/index.ts smoke",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:int": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "7.0.0",
    "@modelcontextprotocol/sdk": "1.12.1",
    "@node-rs/argon2": "2.0.2",
    "@onenomad/przm-access": "0.1.1",
    "@onenomad/przm-cortex-adapter-bitbucket": "workspace:*",
    "@onenomad/przm-cortex-adapter-confluence": "workspace:*",
    "@onenomad/przm-cortex-adapter-github": "workspace:*",
    "@onenomad/przm-cortex-adapter-jira": "workspace:*",
    "@onenomad/przm-cortex-adapter-linear": "workspace:*",
    "@onenomad/przm-cortex-adapter-loom": "workspace:*",
    "@onenomad/przm-cortex-adapter-notion": "workspace:*",
    "@onenomad/przm-cortex-adapter-obsidian": "workspace:*",
    "@onenomad/przm-cortex-adapter-sdk": "workspace:*",
    "@onenomad/przm-cortex-adapter-slack": "workspace:*",
    "@onenomad/przm-cortex-cache-sqlite": "workspace:*",
    "@onenomad/przm-cortex-core": "workspace:*",
    "@onenomad/przm-cortex-dashboard": "workspace:*",
    "@onenomad/przm-cortex-github-auth": "workspace:*",
    "@onenomad/przm-cortex-llm-core": "workspace:*",
    "@onenomad/przm-cortex-memory-pgvector": "workspace:*",
    "@onenomad/przm-cortex-pipeline-code": "workspace:*",
    "@onenomad/przm-cortex-pipeline-code-dossier": "workspace:*",
    "@onenomad/przm-cortex-pipeline-conversation": "workspace:*",
    "@onenomad/przm-cortex-pipeline-core": "workspace:*",
    "@onenomad/przm-cortex-pipeline-doc": "workspace:*",
    "@onenomad/przm-cortex-pipeline-meeting": "workspace:*",
    "jose": "5.9.0",
    "pdf-parse": "2.4.5",
    "ws": "8.18.0",
    "yaml": "2.6.0",
    "zod": "3.23.8",
    "zod-to-json-schema": "3.23.5"
  },
  "optionalDependencies": {
    "@onenomad/przm-cortex-llm-sdk": "workspace:*",
    "@onenomad/przm-cortex-provider-ollama": "workspace:*",
    "@onenomad/przm-cortex-provider-openrouter": "workspace:*"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "cross-env": "^7.0.3",
    "eslint": "^9.12.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
